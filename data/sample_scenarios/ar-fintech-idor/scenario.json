    "decisions": [
        {
            "id": "decision_001_diagnosis",
            "title": "API Spike",
            "description": "47k requests/min. Block IP or analyze code?",
            "phase": "detection",
            "required_role": "analista",
            "difficulty": "high",
            "options": [
                {
                    "id": "d1_analyze_code",
                    "text": "Analyze Code (Root Cause)",
                    "description": "Review permission validation on endpoint.",
                    "is_correct": true,
                    "consequences": {
                        "immediate": {
                            "integridadDatos": 30,
                            "message": "Confirmed: Missing authorization check. It's an IDOR."
                        },
                        "unlocks_decisions": [
                            "decision_002_containment"
                        ]
                    },
                    "educational_note": "CORRECT. Understanding it's an IDOR is key to avoid wasting time blocking rotating IPs."
                },
                {
                    "id": "d1_block_ip",
                    "text": "Block IP in WAF",
                    "description": "Add blocking rule.",
                    "is_correct": false,
                    "consequences": {
                        "immediate": {
                            "integridadDatos": -20,
                            "message": "Failed. Attacker rotates IPs and continues stealing. You lost time."
                        }
                    },
                    "educational_note": "ERROR. Whac-A-Mole with IPs doesn't work against automation."
                }
            ]
        },
        {
            "id": "decision_002_containment",
            "title": "Patching Strategy",
            "description": "The IDOR is obvious. Hotfix or shut down the API?",
            "phase": "containment",
            "required_role": "analista",
            "difficulty": "critical",
            "options": [
                {
                    "id": "d2_hotfix",
                    "text": "Deploy AuthZ Hotfix",
                    "description": "Add ownership validation in code.",
                    "is_correct": true,
                    "consequences": {
                        "immediate": {
                            "integridadDatos": 50,
                            "confianzaStakeholder": 20,
                            "message": "Attack stopped surgically. Legitimate users operate normally."
                        },
                        "unlocks_decisions": [
                            "decision_003_compliance"
                        ]
                    },
                    "educational_note": "CORRECT. Definitive solution that maintains availability."
                },
                {
                    "id": "d2_shutdown",
                    "text": "Shut down Endpoint (Service Down)",
                    "description": "Leave everyone without service.",
                    "is_correct": false,
                    "consequences": {
                        "immediate": {
                            "confianzaStakeholder": -40,
                            "message": "You stopped the attack, but caused a DoS to your own business. CEO is furious."
                        },
                        "game_over": false
                    },
                    "educational_note": "ERROR. Only use 'Nuclear Option' if there's no capacity for a quick fix."
                }
            ]
        },
        {
            "id": "decision_003_compliance",
            "title": "Notification Dilemma",
            "description": "Ley 25.326 does not explicitly mandate today, but it is 'best practice'. Notify?",
            "phase": "compliance",
            "required_role": "ciso",
            "difficulty": "high",
            "options": [
                {
                    "id": "d3_notify_proactive",
                    "text": "Notify AAIP and Clients (Proactive)",
                    "description": "Total transparency.",
                    "is_correct": true,
                    "consequences": {
                        "immediate": {
                            "cumplimientoLegal": 30,
                            "confianzaStakeholder": 30,
                            "message": "AAIP values the gesture. Positive press for transparency."
                        }
                    },
                    "educational_note": "CORRECT. Ethics and long-term reputation are worth more than short-term silence."
                },
                {
                    "id": "d3_silence",
                    "text": "Do not notify (Legally permitted)",
                    "description": "Avoid the scandal today.",
                    "is_correct": false,
                    "consequences": {
                        "immediate": {
                            "confianzaStakeholder": -60,
                            "cumplimientoLegal": -50,
                            "message": "Breach leaks in 3 months. 'Cover-up' scandal. Criminal charges."
                        },
                        "game_over": true,
                        "game_over_reason": "Reputation destroyed by cover-up."
                    },
                    "educational_note": "FATAL. The 'cover-up' is always worse than the crime."
                }
            ]
        }
