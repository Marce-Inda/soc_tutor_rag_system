    "decisions": [
        {
            "id": "decision_001_diagnosis",
            "title": "Spike en API",
            "description": "47k requests/min. ¿Bloquear IP o analizar código?",
            "phase": "detection",
            "required_role": "analista",
            "difficulty": "high",
            "options": [
                {
                    "id": "d1_analyze_code",
                    "text": "Analizar Código (Root Cause)",
                    "description": "Revisar validación de permisos en endpoint.",
                    "is_correct": true,
                    "consequences": {
                        "immediate": {
                            "integridadDatos": 30,
                            "message": "Confirmado: Falta check de autorización. Es un IDOR."
                        },
                        "unlocks_decisions": [
                            "decision_002_containment"
                        ]
                    },
                    "educational_note": "CORRECTO. Entender que es un IDOR es clave para no perder tiempo bloqueando IPs rotativas."
                },
                {
                    "id": "d1_block_ip",
                    "text": "Bloquear IP en WAF",
                    "description": "Agregar regla de bloqueo.",
                    "is_correct": false,
                    "consequences": {
                        "immediate": {
                            "integridadDatos": -20,
                            "message": "Fallo. Atacante rota IP y sigue robando. Perdiste tiempo."
                        }
                    },
                    "educational_note": "ERROR. Whac-A-Mole con IPs no sirve contra automatización."
                }
            ]
        },
        {
            "id": "decision_002_containment",
            "title": "Estrategia de Parcheo",
            "description": "El IDOR es obvio. ¿Hotfix o bajar la API?",
            "phase": "containment",
            "required_role": "analista",
            "difficulty": "critical",
            "options": [
                {
                    "id": "d2_hotfix",
                    "text": "Deploy Hotfix AuthZ",
                    "description": "Agregar validación de ownership en código.",
                    "is_correct": true,
                    "consequences": {
                        "immediate": {
                            "integridadDatos": 50,
                            "confianzaStakeholder": 20,
                            "message": "Ataque detenido quirúrgicamente. Usuarios legítimos operan normal."
                        },
                        "unlocks_decisions": [
                            "decision_003_compliance"
                        ]
                    },
                    "educational_note": "CORRECTO. Solución definitiva que mantiene disponibilidad."
                },
                {
                    "id": "d2_shutdown",
                    "text": "Apagar Endpoint (Service Down)",
                    "description": "Dejar sin servicio a todos.",
                    "is_correct": false,
                    "consequences": {
                        "immediate": {
                            "confianzaStakeholder": -40,
                            "message": "Detuviste el ataque, pero causaste un DoS a tu propio negocio. CEO furioso."
                        },
                        "game_over": false
                    },
                    "educational_note": "ERROR. Solo usar 'Nuclear Option' si no hay capacidad de fix rápido."
                }
            ]
        },
        {
            "id": "decision_003_compliance",
            "title": "Dilema de Notificación",
            "description": "Ley 25.326 no obliga explícitamente hoy, pero es 'best practice'. ¿Notificar?",
            "phase": "compliance",
            "required_role": "ciso",
            "difficulty": "high",
            "options": [
                {
                    "id": "d3_notify_proactive",
                    "text": "Notificar AAIP y Clientes (Proactivo)",
                    "description": "Transparencia total.",
                    "is_correct": true,
                    "consequences": {
                        "immediate": {
                            "cumplimientoLegal": 30,
                            "confianzaStakeholder": 30,
                            "message": "AAIP valora el gesto. Prensa positiva por transparencia."
                        }
                    },
                    "educational_note": "CORRECTO. La ética y la reputación a largo plazo valen más que el silencio corto plazo."
                },
                {
                    "id": "d3_silence",
                    "text": "No notificar (Legalmente permitido)",
                    "description": "Ahorrar el escándalo hoy.",
                    "is_correct": false,
                    "consequences": {
                        "immediate": {
                            "confianzaStakeholder": -60,
                            "cumplimientoLegal": -50,
                            "message": "Se filtra en 3 meses. Escándalo de 'encubrimiento'. Denuncia penal."
                        },
                        "game_over": true,
                        "game_over_reason": "Reputación destruida por encubrimiento."
                    },
                    "educational_note": "FATAL. El 'cover-up' siempre es peor que el crimen."
                }
            ]
        }
